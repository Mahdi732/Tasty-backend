    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.6",
    "mongoose": "^8.10.1",
    "nodemailer": "^6.10.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "rate-limit-redis": "^4.2.2",
    "redis": "^4.7.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
