{
  "name": "tasty-auth-service",
  "version": "1.0.0",
  "description": "Production-grade Auth Service for Tasty microservices platform",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
